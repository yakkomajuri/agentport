# Copy to .env and fill in anything you need. Every value here is optional —
# the defaults in docker-compose.yml are enough to boot locally.

# Signing key for session JWTs. If you leave this unset, the container
# generates a random one on first boot and persists it to the data volume
# (so it's stable across restarts). Set it explicitly if you want to pin it.
# JWT_SECRET_KEY=

# Google login (only if you want to log in with Google in the UI).
# GOOGLE_LOGIN_CLIENT_ID=
# GOOGLE_LOGIN_CLIENT_SECRET=

# OAuth credentials for specific integrations (one pair per provider).
# OAUTH_GITHUB_CLIENT_ID=
# OAUTH_GITHUB_CLIENT_SECRET=

# Transactional email via Resend (leave empty + SKIP_EMAIL_VERIFICATION=true
# for local dev, which is the default in docker-compose.yml).
# RESEND_API_KEY=
# EMAIL_FROM=noreply@example.com

# PostHog analytics (optional).
# POSTHOG_PROJECT_TOKEN=
